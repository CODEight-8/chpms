# Database (used by docker-compose and the app)
DB_PASSWORD=chpms_Secure_2026!

# Application database URL (for local dev without Docker)
DATABASE_URL="postgresql://chpms_user:chpms_Secure_2026!@localhost:5432/chpms"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate_a_random_secret_here

# NextAuth URL — set to your Tailscale IP for remote access
# Local:     http://localhost:3000
# Tailscale: http://100.x.x.x:3000
NEXTAUTH_URL=http://localhost:3000

# Default Owner Account (used by seed script on first run only)
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change_this_strong_password

# System Mode — "live" for primary facility PC, "snapshot" for backup copies
SYSTEM_MODE=live

# Snapshot Timestamp — only set when running in snapshot mode (ISO format)
# SNAPSHOT_TIMESTAMP=2026-04-01T12:00:00Z

# Backup Retention
BACKUP_RETENTION_DAYS=7
BACKUP_RETENTION_WEEKS=4

# Docker API version — uncomment if you get "Internal Server Error for API route"
# DOCKER_API_VERSION=1.43
