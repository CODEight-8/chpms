# Database (used by docker-compose and the app)
DB_PASSWORD=your_strong_password_here

# Application database URL (for local dev without Docker)
DATABASE_URL="postgresql://chpms_user:your_strong_password_here@localhost:5432/chpms"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# Default Owner Account (used by seed script on first run only)
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change_this_strong_password
