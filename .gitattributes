# Force LF line endings for files that run in Linux containers
*.sh text eol=lf
Dockerfile text eol=lf
docker-compose*.yml text eol=lf
.dockerignore text eol=lf
docker-entrypoint.sh text eol=lf

# Standard text files — auto-detect but normalize to LF in repo
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sql text eol=lf
*.prisma text eol=lf

# Binary files — do not modify
*.woff2 binary
*.png binary
*.jpg binary
*.ico binary
